node_modules/
package-lock.json

# Keystore files
*.jks
*.keystore
android/key.properties

# Environment and secrets
.env
.env.*
*.env

# Supabase local config
supabase/.temp/
supabase/.branches/
.supabase/

# Service account keys (NEVER commit these)
*-service-account*.json
firebase-adminsdk*.json

# Local configuration
local.properties
